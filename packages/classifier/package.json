{
  "name": "@warp-protocol/classifier",
  "version": "0.4.0",
  "description": "ML feature extraction and ONNX inference for agent classification",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@warp-protocol/scanner": "workspace:*",
    "onnxruntime-node": "^1.17.0",
    "pino": "^8.17.2"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "tsup": "^8.0.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.1"
  },
  "license": "MIT"
}
