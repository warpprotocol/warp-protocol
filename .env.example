# Solana RPC Configuration
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com
SOLANA_WS_URL=wss://api.mainnet-beta.solana.com
SOLANA_RPC_URL_DEVNET=https://api.devnet.solana.com
SOLANA_WS_URL_DEVNET=wss://api.devnet.solana.com

# Helius RPC (recommended for production)
HELIUS_API_KEY=your_helius_api_key_here
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_helius_api_key_here

# Warp Protocol API
WARP_API_PORT=3100
WARP_API_HOST=0.0.0.0
WARP_API_URL=http://localhost:3100

# API Authentication
WARP_API_KEY=your_api_key_here
WARP_API_SECRET=your_api_secret_here

# On-Chain Program IDs
WARP_ATTESTATION_PROGRAM_ID=WarpAttest111111111111111111111111111111111
WARP_AUTHORITY_KEYPAIR_PATH=./keys/authority.json

# ML Inference Server
INFERENCE_SERVER_URL=http://localhost:8000
INFERENCE_BATCH_SIZE=32
INFERENCE_TIMEOUT_MS=5000

# ONNX Model Path
ONNX_MODEL_PATH=./models/training/exports/classifier_v4.onnx

# Database (optional, for caching verdicts)
REDIS_URL=redis://localhost:6379
REDIS_TTL_SECONDS=300

# Logging
LOG_LEVEL=info
LOG_FORMAT=json

# Scanner Configuration
SCANNER_BATCH_SIZE=50
SCANNER_POLL_INTERVAL_MS=1000
SCANNER_MAX_RETRIES=5
SCANNER_RETRY_DELAY_MS=2000

# Feature Extraction
FEATURE_LOOKBACK_SLOTS=1000
FEATURE_MIN_TX_COUNT=5

# Monitoring
METRICS_ENABLED=true
METRICS_PORT=9090
